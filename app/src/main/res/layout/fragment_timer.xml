<?xml version="1.0" encoding="utf-8"?>
<ScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp">

        <!-- 顶部标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="计时器"
            android:textSize="28sp"
            android:textColor="#1A1E2B"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp"
            android:letterSpacing="0.01" />

        <!-- 圆形进度条容器 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginVertical="16dp">

            <!-- 自定义圆形进度条 -->
            <com.example.timer.views.CircularProgressView
                android:id="@+id/circularProgress"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_centerInParent="true"
                app:progressColor="#4A80F0"
                app:backgroundColor="#E8ECF2"
                app:progressWidth="8dp" />

            <!-- 中心时间显示 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTimerDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textSize="42sp"
                    android:textColor="#1A1E2B"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="剩余时间"
                    android:textSize="14sp"
                    android:textColor="#7C829C"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"
                    android:id="@+id/tvTimeRemainingLabel" />
            </LinearLayout>
        </RelativeLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#E5E9F0"
            android:layout_marginVertical="24dp" />

        <!-- 时间设置区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置时间"
            android:textSize="16sp"
            android:textColor="#1A1E2B"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp" />

        <!-- 小时/分钟/秒选择器 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:gravity="center_vertical">

            <!-- 小时设置 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小时"
                    android:textSize="14sp"
                    android:textColor="#7C829C"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/btnHourDecrease"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_minus"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F0F2F6"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="减少小时" />

                    <TextView
                        android:id="@+id/tvHours"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="00"
                        android:textSize="32sp"
                        android:textColor="#1A1E2B"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:includeFontPadding="false" />

                    <ImageButton
                        android:id="@+id/btnHourIncrease"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_plus"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F0F2F6"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="增加小时" />
                </LinearLayout>
            </LinearLayout>

            <!-- 分钟设置 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分钟"
                    android:textSize="14sp"
                    android:textColor="#7C829C"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/btnMinuteDecrease"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_minus"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F0F2F6"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="减少分钟" />

                    <TextView
                        android:id="@+id/tvMinutes"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="00"
                        android:textSize="32sp"
                        android:textColor="#1A1E2B"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:includeFontPadding="false" />

                    <ImageButton
                        android:id="@+id/btnMinuteIncrease"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_plus"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F0F2F6"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="增加分钟" />
                </LinearLayout>
            </LinearLayout>

            <!-- 秒设置 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="秒"
                    android:textSize="14sp"
                    android:textColor="#7C829C"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageButton
                        android:id="@+id/btnSecondDecrease"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_minus"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F0F2F6"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="减少秒" />

                    <TextView
                        android:id="@+id/tvSeconds"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="00"
                        android:textSize="32sp"
                        android:textColor="#1A1E2B"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:includeFontPadding="false" />

                    <ImageButton
                        android:id="@+id/btnSecondIncrease"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_plus"
                        android:background="@drawable/circle_button_bg"
                        android:backgroundTint="#F0F2F6"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        android:contentDescription="增加秒" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#E5E9F0"
            android:layout_marginVertical="24dp" />

        <!-- 快捷预设时间 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="快速预设"
            android:textSize="16sp"
            android:textColor="#1A1E2B"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <Button
                    android:id="@+id/btnPreset1"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:text="5分钟"
                    android:textSize="14sp"
                    android:textColor="#4A80F0"
                    android:background="@drawable/preset_button_bg"
                    android:backgroundTint="#E8F0FE"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="10dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

                <Button
                    android:id="@+id/btnPreset2"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:text="10分钟"
                    android:textSize="14sp"
                    android:textColor="#4A80F0"
                    android:background="@drawable/preset_button_bg"
                    android:backgroundTint="#E8F0FE"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="10dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

                <Button
                    android:id="@+id/btnPreset3"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:text="15分钟"
                    android:textSize="14sp"
                    android:textColor="#4A80F0"
                    android:background="@drawable/preset_button_bg"
                    android:backgroundTint="#E8F0FE"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="10dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

                <Button
                    android:id="@+id/btnPreset4"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:text="30分钟"
                    android:textSize="14sp"
                    android:textColor="#4A80F0"
                    android:background="@drawable/preset_button_bg"
                    android:backgroundTint="#E8F0FE"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="10dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

                <Button
                    android:id="@+id/btnPreset5"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:text="1小时"
                    android:textSize="14sp"
                    android:textColor="#4A80F0"
                    android:background="@drawable/preset_button_bg"
                    android:backgroundTint="#E8F0FE"
                    android:fontFamily="sans-serif-medium"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- 铃声选择卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="闹钟铃声"
                android:textSize="16sp"
                android:textColor="#1A1E2B"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F8F9FA"
                android:padding="12dp"
                android:baselineAligned="false">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_music"
                    android:tint="#4A80F0"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvSelectedRingtone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="默认铃声 (水滴)"
                    android:textSize="15sp"
                    android:textColor="#1A1E2B"
                    android:fontFamily="sans-serif"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <Button
                    android:id="@+id/btnSelectRingtone"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="更换"
                    android:textSize="13sp"
                    android:textColor="#4A80F0"
                    android:background="@drawable/outline_button_bg"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="0dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />
            </LinearLayout>

            <!-- 震动选项 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_vibrate"
                    android:tint="#4A80F0"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="震动提醒"
                    android:textSize="15sp"
                    android:textColor="#1A1E2B"
                    android:fontFamily="sans-serif" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchVibrate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="#4A80F0"
                    android:trackTint="#C2D9FF" />
            </LinearLayout>
        </LinearLayout>

        <!-- 控制按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="28dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnStartPause"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="开始计时"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/primary_button_bg"
                android:backgroundTint="#4A80F0"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="重置"
                android:textSize="16sp"
                android:textColor="#7C829C"
                android:background="@drawable/secondary_button_bg"
                android:backgroundTint="#F0F2F6"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:elevation="2dp" />
        </LinearLayout>

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/tvTimerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="点击开始按钮启动计时器"
            android:textSize="13sp"
            android:textColor="#7C829C"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:visibility="visible" />

    </LinearLayout>
</ScrollView>
